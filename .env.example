# ============================================================
# Dr Prompt – Environment Variables Template
# ============================================================
# Copy this to .env for local development.
# For Render deployment, set these in the Render dashboard
# (Environment → Add Environment Variable) or via render.yaml.
# ⚠️  NEVER commit your actual .env to git.
# ============================================================

# ====================
# 🌐 SERVER
# ====================
PORT=8000                         # Render overrides this with 10000

# ====================
# 🤖 LLM ROUTING MODE
# ====================
# Choose one: ngrok | api | local | auto
OLLAMA_MODE=ngrok

# --- NGROK MODE (default) ----
# Start ngrok locally: ngrok http 11434
# Paste the public URL here:
NGROK_URL=https://xxxxx.ngrok-free.app

# --- API MODE ----------------
# OpenAI-compatible API credentials (Groq, OpenAI, etc.)
OPENAI_API_KEY=sk-...            # Set in Render dashboard, never commit
GROQ_API_KEY=gsk_...             # Set in Render dashboard, never commit
API_BASE_URL=https://api.groq.com/openai/v1   # or https://api.openai.com/v1

# --- LOCAL MODE --------------
# Direct Ollama endpoint (e.g. when running backend locally)
LOCAL_OLLAMA_URL=http://localhost:11434

# ====================
# 🧠 MODEL
# ====================
DEFAULT_MODEL=phi3                # Used in all modes

# ====================
# 📊 MLFLOW
# ====================
# Keep as file:./mlruns for local tracking (no cloud server needed)
MLFLOW_TRACKING_URI=file:./mlruns

# ====================
# 🔒 CORS
# ====================
# Comma-separated list; use * for development only
ALLOWED_ORIGINS=*
